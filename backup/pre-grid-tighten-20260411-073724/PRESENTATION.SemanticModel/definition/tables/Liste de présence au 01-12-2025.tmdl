	partition 'Liste de présence au 01-12-2025' = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents("P:\PRESENTATION DATA RH\DONNEES RH Decembre 2025 MALI V2.xlsx"), null, true),
				    Liste_Initiale_Table = Source{[Item="Liste_Initiale",Kind="Table"]}[Data],
				    #"Type modifié" = Table.TransformColumnTypes(Liste_Initiale_Table,{{"Société", type text}, {"Matricule", Int64.Type}, {"USER ID", Int64.Type}, {"Nom", type text}, {"Prénom", type text}, {"Sexe", type text}, {"Date de naissance", type date}, {"Age", Int64.Type}, {"Date d'embauche", type date}, {"Direction", type text}, {"Département", type text}, {"Service", type text}, {"Poste harmonisé", type text}, {"Fonction", type text}, {"Date d'entrée", type date}, {"CODE Analytique", type text}, {"Affectation Analytique ", type text}, {"Catégorie conventionnelle", type text}, {"Type de contrat", type text}, {"Si CDD ou stagiaire, merci de préciser la date de fin de contrat", type text}, {"Statut Local ou Expatrié?", type text}, {"Nationalité", type text}, {"Ancienneté2", Int64.Type}, {"Tranche d'age", type text}, {"Tranche d'ancienneté", type text}})
				in
				    #"Type modifié"

	annotation PBI_ResultType = Table


table 'Liste de présence au 01-12-2025'
	lineageTag: d9c45a9e-711c-442c-a3ca-351c7150695a

	measure Headcount =
			VAR _headcount =
				CALCULATE(
					DISTINCTCOUNT('Liste de présence au 01-12-2025'[USER ID]),
					'Liste de présence au 01-12-2025'[USER ID] <> BLANK()
				)
			RETURN IF(_headcount = 0, BLANK(), _headcount)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 80b55da1-bfe6-4c71-b666-7c39afaae821

	measure 'Age Moyen' =
			AVERAGEX(
				FILTER(
					'Liste de présence au 01-12-2025',
					'Liste de présence au 01-12-2025'[USER ID] <> BLANK()
				),
				'Liste de présence au 01-12-2025'[Age]
			)
		formatString: 0.0" ans"
		displayFolder: 'Dashboard RH'
		lineageTag: 906aa09f-1f5e-4a22-9bbd-844a4c5eebb2

	measure 'Femmes Actives' =
			VAR _femmes =
				CALCULATE(
					DISTINCTCOUNT('Liste de présence au 01-12-2025'[USER ID]),
					'Liste de présence au 01-12-2025'[USER ID] <> BLANK(),
					'Liste de présence au 01-12-2025'[Sexe] = "Féminin"
				)
			RETURN IF(_femmes = 0, BLANK(), _femmes)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: e2a7df8c-7d3d-422f-8bd7-cbaef1905154

	measure 'Taux de Diversité' = DIVIDE([Femmes Actives], [Headcount])
		formatString: 0.0%
		displayFolder: 'Dashboard RH'
		lineageTag: 0c964894-818e-4b1f-9f10-b9f6deffeb70

	measure 'Ancienneté Moyenne' =
			AVERAGEX(
				FILTER(
					'Liste de présence au 01-12-2025',
					'Liste de présence au 01-12-2025'[USER ID] <> BLANK()
				),
				'Liste de présence au 01-12-2025'[Ancienneté2]
			)
		formatString: 0.0" ans"
		displayFolder: 'Dashboard RH'
		lineageTag: a54bd686-852a-4541-a8d6-4c9a3863a4d8

	measure 'Locaux Actifs' = CALCULATE([Headcount], 'Liste de présence au 01-12-2025'[Statut Local ou Expatrié?] = "Local")
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: a30a9e24-da13-42bd-8509-ecef20b6a935

	measure 'Expatriés Actifs' = CALCULATE([Headcount], 'Liste de présence au 01-12-2025'[Statut Local ou Expatrié?] = "Expatrié")
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 6a6b6e84-0d8f-44ba-bf20-e5a436469e4e

	measure 'Départs 2025' =
			CALCULATE(
				COUNTROWS('Départ'),
				FILTER('Départ', YEAR('Départ'[Date de départ]) = 2025)
			)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 36dceb8e-45d8-4b4f-9b7a-db7e8a837c0f

	measure 'Recrutements 2025' =
			CALCULATE(
				COUNTROWS(Embauche),
				FILTER(Embauche, YEAR(Embauche[Date d'embauche]) = 2025)
			)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 75b11b25-556f-4867-9fdf-e9eef3ec9faf

	measure 'Mobilité 2025' =
			CALCULATE(
				COUNTROWS('Départ'),
				FILTER(
					'Départ',
					YEAR('Départ'[Date de départ]) = 2025
						&& (
							CONTAINSSTRING(LOWER('Départ'[Motif de départ]), "mobilit")
							|| NOT ISBLANK('Départ'[Précisez pays si mobilité])
						)
				)
			)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 7f74050f-d351-47b2-adf1-8ad8aaefe417

	measure 'Turnover 2025' = DIVIDE([Départs 2025], [Headcount])
		formatString: 0.0%
		displayFolder: 'Dashboard RH'
		lineageTag: 48234881-5dd0-4433-9b2d-44607a379057


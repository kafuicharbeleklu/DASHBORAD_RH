				    #"FillDownMonth" = Table.FillDown(#"RenameColumns", {"Mois"}),
				    #"FilteredRows" = Table.SelectRows(#"FillDownMonth", each ([Nom] <> null and Text.Trim(Text.From([Nom])) <> "") or ([SortieUserID] <> null and Text.Trim(Text.From([SortieUserID])) <> "")),
				    #"AddLevel" = Table.AddColumn(#"FilteredRows", "Level", each let _raw = Text.Upper(Text.Trim(Text.From([LevelRaw]))) in if _raw = "N4" or _raw = "4" then "Level 4" else if _raw = "N3C" or _raw = "3C" then "Level 3C" else if _raw = "N3B" or _raw = "3B" then "Level 3B" else if _raw = "N3A" or _raw = "3A" then "Level 3A" else if _raw = "N2C" or _raw = "2C" then "Level 2C" else if _raw = "N2B" or _raw = "2B" then "Level 2B" else if _raw = "N2A" or _raw = "2A" then "Level 2A" else if _raw = "N3" or _raw = "3" then "Level 3" else if _raw = "N2" or _raw = "2" then "Level 2" else if _raw = "N1" or _raw = "1" then "Level 1" else _raw, type text),
				    #"AddMonthDate" = Table.AddColumn(#"AddLevel", "MonthDate", each Date.FromText("01-" & Text.From([Mois]), [Culture = "fr-FR"]), type date),
				    #"AddMonthOrder" = Table.AddColumn(#"AddMonthDate", "MonthOrder", each Date.Year([MonthDate]) * 100 + Date.Month([MonthDate]), Int64.Type),
				    #"AddLeaveType" = Table.AddColumn(#"AddMonthOrder", "LeaveType", each let _motif = Text.Lower(Text.From([Motif])) in if Text.Contains(_motif, "démission") or Text.Contains(_motif, "abandon") then "Voluntary" else "Other", type text),
				    #"SelectOutput" = Table.SelectColumns(#"AddLeaveType", {"SortieUserID", "Nom", "Prenoms", "Level", "Mois", "MonthOrder", "Motif", "LeaveType"})
				in
				    #"SelectOutput"

	annotation PBI_ResultType = Table


	partition 'TCDP Sorties' = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents("P:\PRESENTATION DATA RH\DONNEES RH Decembre 2025 MALI V2.xlsx"), null, true),
				    TCDP_Sheet = Source{[Item="TCDP",Kind="Sheet"]}[Data],
				    #"SkipToDetail" = Table.Skip(TCDP_Sheet, 20),

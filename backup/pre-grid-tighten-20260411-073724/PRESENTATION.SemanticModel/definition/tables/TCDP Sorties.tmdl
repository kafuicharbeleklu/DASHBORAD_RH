table 'TCDP Sorties'
	lineageTag: 954af3ff-1318-4b98-8c25-245a910ca101

	measure 'TCDP Leaves Count' = COUNTROWS('TCDP Sorties')
		formatString: 0
		displayFolder: 'TCDP'
		lineageTag: 954af3ff-1318-4b98-8c25-245a910ca102

	measure 'TCDP Voluntary Leaves' =
			CALCULATE(
				[TCDP Leaves Count],
				'TCDP Sorties'[LeaveType] = "Voluntary"
			)
		formatString: 0
		displayFolder: 'TCDP'
		lineageTag: 954af3ff-1318-4b98-8c25-245a910ca103

	measure 'TCDP Voluntary Leaves %' = DIVIDE([TCDP Voluntary Leaves], [TCDP Leaves Count])
		formatString: 0.0%
		displayFolder: 'TCDP'
		lineageTag: 954af3ff-1318-4b98-8c25-245a910ca104

	measure 'TCDP Leaves Level 3C' =
			CALCULATE(
				[TCDP Leaves Count],
				'TCDP Sorties'[Level] = "Level 3C"
			)
		formatString: 0
		displayFolder: 'TCDP'
		lineageTag: 954af3ff-1318-4b98-8c25-245a910ca105

	measure 'TCDP Leaves Level 4' =
			CALCULATE(
				[TCDP Leaves Count],
				'TCDP Sorties'[Level] = "Level 4"
			)
		formatString: 0
		displayFolder: 'TCDP'
		lineageTag: 954af3ff-1318-4b98-8c25-245a910ca106

	measure 'TCDP Leaves Level 3C & 4' = [TCDP Leaves Level 3C] + [TCDP Leaves Level 4]
		formatString: 0
		displayFolder: 'TCDP'
		lineageTag: 954af3ff-1318-4b98-8c25-245a910ca10f


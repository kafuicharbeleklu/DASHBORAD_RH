table 'HR Date'
	lineageTag: 4cf2a1e9-ea32-4744-96cb-0a8c4a6b8201

	column Date
		dataType: dateTime
		formatString: Long Date
		lineageTag: 4cf2a1e9-ea32-4744-96cb-0a8c4a6b8202
		summarizeBy: none
		sourceColumn: Date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	partition 'HR Date' = m
		mode: import
		source =
				let
				    Source = List.Sort(
				        List.Distinct(
				            List.Combine(
				                {
				                    List.RemoveNulls(Table.Column(Recrutement, "DATE")),
				                    List.RemoveNulls(Table.Column(Formation, "DATE")),
				                    List.RemoveNulls(Table.Column(Absence, "DATE")),
				                    List.RemoveNulls(Table.Column(#"Masse salariale", "DATE"))
				                }
				            )
				        )
				    ),
				    #"ToTable" = Table.FromList(Source, Splitter.SplitByNothing(), {"Date"}),
				    #"ChangedType" = Table.TransformColumnTypes(#"ToTable", {{"Date", type date}})
				in
				    #"ChangedType"

	annotation PBI_ResultType = Table

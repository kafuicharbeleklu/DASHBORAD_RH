table Départ
	lineageTag: ba70b40d-acf2-4890-9824-a3f6d038950b

	measure 'Departures Count' =
			VAR _count =
				CALCULATE(
					COUNTROWS('Départ'),
					'Départ'[Date de départ] <> BLANK()
				)
			RETURN COALESCE(_count, 0)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 3f0cb8d6-6fb2-4c3f-8c62-0c9c4fba0101

	measure 'Voluntary Leaves' =
			CALCULATE(
				[Departures Count],
				'Départ'[LeaveType] = "Voluntary"
			)
		formatString: 0
		displayFolder: 'Dashboard RH'
		lineageTag: 3f0cb8d6-6fb2-4c3f-8c62-0c9c4fba0102

	measure 'Voluntary Leave Rate' = DIVIDE([Voluntary Leaves], [Departures Count])
		formatString: 0.0%
		displayFolder: 'Dashboard RH'
		lineageTag: 3f0cb8d6-6fb2-4c3f-8c62-0c9c4fba0103


	partition Départ = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents("P:\PRESENTATION DATA RH\DONNEES RH Decembre 2025 MALI V2.xlsx"), null, true),
				    Départ_Sheet = Source{[Item="Départ",Kind="Sheet"]}[Data],
				    #"En-têtes promus" = Table.PromoteHeaders(Départ_Sheet, [PromoteAllScalars=true]),
				    #"Type modifié" = Table.TransformColumnTypes(#"En-têtes promus",{{"Société", type text}, {"Matricule", type any}, {"User ID", Int64.Type}, {"Nom", type text}, {"Prénom", type text}, {"Sexe", type text}, {"Date de naissance", type date}, {"Age", Int64.Type}, {"Date d'embauche", type date}, {"Direction", type text}, {"Département", type text}, {"Service", type text}, {"Poste harmonisé", type text}, {"Fonction", type text}, {"Date d'entrée", type date}, {"CODE Analytique", type text}, {"Affectation Analytique ", type text}, {"Catégorie conventionnelle", type text}, {"Type de contrat", type text}, {"Si CDD ou stagiaire, merci de préciser la date de fin de contrat", type date}, {"Statut Local ou Expatrié?", type text}, {"Nationalité", type text}, {"Ancienneté", Int64.Type}, {"Date de départ", type date}, {"Motif de départ", type text}, {"Précisez pays si mobilité", type text}, {"Niveau TCDP", type any}, {"Colonne1", type any}, {"Colonne2", type any}, {"Colonne3", type any}}),
				    #"LeaveType ajouté" = Table.AddColumn(#"Type modifié", "LeaveType", each let _motif = Text.Lower(Text.From([Motif de départ])) in if Text.Contains(_motif, "démission") or Text.Contains(_motif, "abandon") or Text.Contains(_motif, "rupture") or Text.Contains(_motif, "disponibilit") then "Voluntary" else "Other", type text)
				in
				    #"LeaveType ajouté"

	annotation PBI_ResultType = Table


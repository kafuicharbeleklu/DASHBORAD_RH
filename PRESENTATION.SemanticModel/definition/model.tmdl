annotation PBI_QueryOrder = ["FolderPathParameter","SourceWorkbookNameParameter","Absence","Formation","Masse salariale","Recrutement","TCDP","Scenario","HR Date","Refresh Info","TCDP Gender","TCDP Levels","TCDP Sorties","TCDP Level Dim","Effectif","Embauches","Departs","AbsenceMensuelle","FormationMensuelle","RecrutementMensuel","RecrutementDetail","MasseSalarialeMensuelle","TCDP_Headcount","TCDP_Entrees","TCDP_Sorties","TCDP_Genre","DIM_Filiale","DIM_TypeContrat","DIM_StatutGeo","DIM_CatConv","DIM_Sexe","DIM_MotifDepart","DIM_MotifRecruit","DIM_TCDPLevel","DIM_Nationalite","DIM_AbsenceType","DIM_MotifSortieTCDP"]

annotation PBI_ProTooling = ["DevMode"]


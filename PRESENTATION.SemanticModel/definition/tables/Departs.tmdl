table Departs
	lineageTag: 9b861758-016f-4909-9217-47d5c9b9364c

	measure 'Departures Count' =
			VAR DepartureCount =
				COUNTROWS(
					FILTER(
						Departs,
						NOT ISBLANK(COALESCE(Departs[DateDepart], Departs[EventDate]))
					)
				)
			RETURN COALESCE(DepartureCount, 0)
		formatString: 0
		displayFolder: 'Overview\Attrition'
		lineageTag: 1a23a795-b57e-4fc8-9d6a-89bbc0456925

	measure 'Voluntary Leaves' =
			CALCULATE(
				[Departures Count],
				FILTER(
					Departs,
					VAR ReasonCode = UPPER(TRIM(COALESCE(Departs[MotifDepartCode], "")))
					RETURN ReasonCode IN {"DEMISSION", "ABANDON", "ABANDON_POSTE"}
				)
			)
		formatString: 0
		displayFolder: 'Overview\Attrition'
		lineageTag: e525561f-c219-483a-9e15-d62f63b50a00

	measure 'Voluntary Leave Rate' = DIVIDE([Voluntary Leaves], [Departures Count], 0)
		formatString: 0.0%
		displayFolder: 'Overview\Attrition'
		lineageTag: 6e2a6af0-9bc7-4760-9fe8-6ba6711f4a20


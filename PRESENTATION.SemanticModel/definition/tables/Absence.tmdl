table Absence
	lineageTag: b21b09b9-e76d-4319-b938-1ead84c4dd47

	measure 'Absence Rate' =
			DIVIDE(
				[Absence Hours],
				[Headcount] * 8 * 21,
				0
			)
		formatString: 0.0%
		displayFolder: 'HR Performance\Absence'
		lineageTag: 3e31c83c-ba60-42ad-ab39-f15609be783b

	measure 'Absence Rate Latest' =
			VAR _lastDate = CALCULATE(MAX(Absence[DATE]), ALL(Absence))
			RETURN CALCULATE([Absence Rate], Absence[DATE] = _lastDate)
		formatString: 0.0%
		displayFolder: 'HR Performance\Absence'
		lineageTag: d369c464-4492-452f-8c8b-00977551e6c7

	measure 'Absence Hours' = SUM(Absence[AbsenceHours])
		formatString: 0
		displayFolder: 'HR Performance\Absence'
		lineageTag: 5fba9a7a-b402-43f4-99ab-b4ac65f5589a

	measure 'Absence Hours Latest' =
			VAR _lastDate = CALCULATE(MAX(Absence[DATE]), ALL(Absence))
			RETURN CALCULATE([Absence Hours], Absence[DATE] = _lastDate)
		formatString: 0
		displayFolder: 'HR Performance\Absence'
		lineageTag: bfcdc5fc-baa7-4d2f-80eb-4bdde7123ab2


	partition Absence = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents(FolderPathParameter & "\" & SourceWorkbookNameParameter), null, true),
				    Absence_Table = Source{[Item="tbl_AbsenceMensuelle",Kind="Table"]}[Data],
				    #"FilteredRows" = Table.SelectRows(Absence_Table, each let _month = try Text.Trim(Text.From([MonthStartDate])) otherwise "" in _month <> ""),
				    ToDate = (value as any) as nullable date =>
				        let
				            _directDate = try Date.From(value) otherwise null,
				            _serial = if _directDate <> null then null else try Number.From(value) otherwise null
				        in
				            if _directDate <> null then _directDate else if _serial <> null then Date.AddDays(#date(1899, 12, 30), _serial) else null,
				    #"ConvertDate" = Table.TransformColumns(#"FilteredRows", {{"MonthStartDate", ToDate, type date}}),
				    #"SelectColumns" = if Table.HasColumns(#"ConvertDate", {"AbsenceRate"}) then Table.SelectColumns(#"ConvertDate", {"MonthStartDate", "OpeningLeaveDays", "LeaveDaysTaken", "LeaveDaysAccrued", "ClosingLeaveDays", "AbsenceHours", "AbsenceRate"}) else Table.SelectColumns(#"ConvertDate", {"MonthStartDate", "OpeningLeaveDays", "LeaveDaysTaken", "LeaveDaysAccrued", "ClosingLeaveDays", "AbsenceHours"}),
				    #"AddAbsenceRate" = if Table.HasColumns(#"SelectColumns", {"AbsenceRate"}) then #"SelectColumns" else Table.AddColumn(#"SelectColumns", "AbsenceRate", each null, type number),
				    #"RenamedColumns" = Table.RenameColumns(#"AddAbsenceRate", {{"MonthStartDate", "DATE"}}),
				    #"ChangedType" = Table.TransformColumns(#"RenamedColumns", {{"OpeningLeaveDays", each try Number.From(_) otherwise null, type number}, {"LeaveDaysTaken", each try Number.From(_) otherwise null, type number}, {"LeaveDaysAccrued", each try Number.From(_) otherwise null, type number}, {"ClosingLeaveDays", each try Number.From(_) otherwise null, type number}, {"AbsenceHours", each try Int64.From(_) otherwise null, Int64.Type}, {"AbsenceRate", each try Number.From(_) otherwise null, type number}})
				in
				    #"ChangedType"

	annotation PBI_ResultType = Table


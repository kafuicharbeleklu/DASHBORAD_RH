	measure 'Average Age' =
			VAR LatestSnapshot =
				CALCULATE(
					MAX(Effectif[SnapshotDate]),
					REMOVEFILTERS(Effectif[SnapshotDate])
				)
			VAR TodayDate = TODAY()
			VAR Population =
				CALCULATETABLE(
					FILTER(
						Effectif,
						NOT ISBLANK(Effectif[EmployeeKey])
							&& NOT ISBLANK(Effectif[DateNaissance])
							&& Effectif[DateNaissance] >= DATE(1900, 1, 1)
							&& Effectif[DateNaissance] <= TodayDate
					),
					FILTER(
						ALL(Effectif[SnapshotDate]),
						Effectif[SnapshotDate] = LatestSnapshot
					)
				)
			RETURN
				AVERAGEX(
					Population,
					VAR BirthDate = Effectif[DateNaissance]
					VAR AnniversaryDay =
						MIN(
							DAY(BirthDate),
							DAY(EOMONTH(DATE(YEAR(TodayDate), MONTH(BirthDate), 1), 0))
						)
					VAR Anniversary = DATE(YEAR(TodayDate), MONTH(BirthDate), AnniversaryDay)
					VAR Years = YEAR(TodayDate) - YEAR(BirthDate)
					RETURN Years - IF(Anniversary > TodayDate, 1, 0)
				)
		formatString: 0.0" ans"
		displayFolder: 'Overview\Population'
		lineageTag: 6fa2c570-960c-4440-87bd-903faf75c972

	measure 'Women Active' =
			CALCULATE(

table Effectif
	lineageTag: ca1b18b6-ab16-4968-bef1-3d20c5188104

	measure 'Headcount Active' =
			VAR LatestSnapshot =
				CALCULATE(
					MAX(Effectif[SnapshotDate]),
					REMOVEFILTERS(Effectif[SnapshotDate])
				)
			RETURN
				COALESCE(
					CALCULATE(
						SUM(Effectif[_EffectifsActifs]),
						FILTER(
							ALL(Effectif[SnapshotDate]),
							Effectif[SnapshotDate] = LatestSnapshot
						)
					),
					0
				)
		formatString: 0
		displayFolder: 'Overview\Workforce'
		lineageTag: 18d1db09-2294-4421-b628-c9b139e283df

	measure Headcount = [Headcount Active]
		formatString: 0
		displayFolder: 'Overview\Workforce'
		lineageTag: f72dc16b-f3ad-4be4-a111-52363740f944


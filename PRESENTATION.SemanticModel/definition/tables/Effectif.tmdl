	column 'Seniority Band'
		dataType: string
		lineageTag: 9674bfa5-9088-4bbc-a2fc-bff09ac7d20d
		summarizeBy: none
		sourceColumn: Seniority Band

		annotation SummarizationSetBy = Automatic

	partition Effectif = m
		mode: import
		source =
				let
				    Source = Excel.Workbook(File.Contents(FolderPathParameter & "\" & SourceWorkbookNameParameter), null, true),
				    EffectifTable = Source{[Item="tbl_Effectif",Kind="Table"]}[Data],
				    #"FilteredRows" = Table.SelectRows(EffectifTable, each let _userId = try Text.Trim(Text.From([UserID])) otherwise "" in _userId <> ""),
				    RefreshDate = Date.From(DateTime.FixedLocalNow()),
				    ToDate = (value as any) as nullable date =>
				        let
				            DirectDate = try Date.From(value) otherwise null,
				            Serial = if DirectDate <> null then null else try Number.From(value) otherwise null
				        in
				            if DirectDate <> null then DirectDate else if Serial <> null then Date.AddDays(#date(1899, 12, 30), Serial) else null,
				    FullYearsBetween = (startDate as nullable date, endDate as nullable date) as nullable number =>
				        if startDate = null or endDate = null then
				            null
				        else
				            let
				                Years = Date.Year(endDate) - Date.Year(startDate),
				                Anniversary = Date.AddYears(startDate, Years)
				            in
				                Years - (if Anniversary > endDate then 1 else 0),
				    SeniorityBand = (years as nullable number) as nullable text =>
				        if years = null then null else
				        if years < 5 then "0-4" else
				        if years < 10 then "05-09" else
				        if years < 15 then "10-14" else
				        if years < 20 then "15-19" else
				        if years < 25 then "20-24" else
				        if years < 30 then "25-29" else
				        "30 et plus",
				    #"ConvertDates" = Table.TransformColumns(#"FilteredRows", {{"SnapshotDate", ToDate, type date}, {"DateNaissance", ToDate, type date}, {"DateEmbauche", ToDate, type date}, {"DateEntree", ToDate, type date}, {"DateFinContrat", ToDate, type date}}),
				    TextColumns = {"FilialeCode", "FilialeName", "Matricule", "Nom", "Prenom", "SexeCode", "Direction", "Departement", "Service", "PosteHarmonise", "Fonction", "CodeAnalytique", "AffectationAnalytique", "CategorieConventionnelleCode", "TypeContratCode", "StatutGeoCode", "NationaliteCode", "NiveauTCDPCode"},
				    #"TrimmedText" = Table.TransformColumns(#"ConvertDates", List.Transform(TextColumns, each {_, (v) => if v = null then null else Text.Trim(Text.From(v)), type text})),
				    #"ChangedNumericTypes" = Table.TransformColumns(#"TrimmedText", {{"SourceYear", each try Int64.From(_) otherwise null, Int64.Type}, {"UserID", each try Int64.From(_) otherwise null, Int64.Type}}),
				    #"AddEmployeeKey" = Table.AddColumn(#"ChangedNumericTypes", "EmployeeKey", each if [FilialeCode] = null or [Matricule] = null or [Matricule] = "" then null else [FilialeCode] & "_" & [Matricule], type text),
				    #"AddActiveFlag" = Table.AddColumn(#"AddEmployeeKey", "_EffectifsActifs", each if [EmployeeKey] = null then 0 else 1, Int64.Type),
				    #"AddSeniorityBand" = Table.AddColumn(#"AddActiveFlag", "Seniority Band", each let EntryDate = if [DateEntree] <> null then [DateEntree] else [DateEmbauche] in SeniorityBand(FullYearsBetween(EntryDate, RefreshDate)), type text),
				    #"SelectOutput" = Table.SelectColumns(#"AddSeniorityBand", {"FilialeCode", "FilialeName", "SnapshotDate", "SourceYear", "Matricule", "EmployeeKey", "UserID", "Nom", "Prenom", "SexeCode", "DateNaissance", "DateEmbauche", "DateEntree", "Direction", "Departement", "Service", "PosteHarmonise", "Fonction", "CodeAnalytique", "AffectationAnalytique", "CategorieConventionnelleCode", "TypeContratCode", "DateFinContrat", "StatutGeoCode", "NationaliteCode", "NiveauTCDPCode", "_EffectifsActifs", "Seniority Band"})
				in
				    #"SelectOutput"

	annotation PBI_ResultType = Table


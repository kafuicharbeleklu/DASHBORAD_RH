		formatString: 0.0%
		displayFolder: 'Overview\Workforce'
		lineageTag: 6917c714-1ff7-496a-a035-9c196e9b9463

	measure 'Average Seniority' =
			VAR LatestSnapshot =
				CALCULATE(
					MAX(Effectif[SnapshotDate]),
					REMOVEFILTERS(Effectif[SnapshotDate])
				)
			VAR TodayDate = TODAY()
			VAR Population =
				CALCULATETABLE(
					FILTER(
						Effectif,
						VAR EntryDate = COALESCE(Effectif[DateEntree], Effectif[DateEmbauche])
						RETURN
							NOT ISBLANK(Effectif[EmployeeKey])
								&& NOT ISBLANK(EntryDate)
								&& EntryDate >= DATE(1900, 1, 1)
								&& EntryDate <= TodayDate
					),
					FILTER(
						ALL(Effectif[SnapshotDate]),
						Effectif[SnapshotDate] = LatestSnapshot
					)
				)
			RETURN
				AVERAGEX(
					Population,
					VAR EntryDate = COALESCE(Effectif[DateEntree], Effectif[DateEmbauche])
					VAR AnniversaryDay =
						MIN(
							DAY(EntryDate),
							DAY(EOMONTH(DATE(YEAR(TodayDate), MONTH(EntryDate), 1), 0))
						)
					VAR Anniversary = DATE(YEAR(TodayDate), MONTH(EntryDate), AnniversaryDay)
					VAR Years = YEAR(TodayDate) - YEAR(EntryDate)
					RETURN Years - IF(Anniversary > TodayDate, 1, 0)
				)
		formatString: 0.0" ans"
		displayFolder: 'Overview\Population'
		lineageTag: bf3dbfdc-1926-4bc1-914a-7557fbc07ce2

	measure 'Departures Current Year' =
			VAR LatestSnapshot =
				CALCULATE(
					MAX(Effectif[SnapshotDate]),
					REMOVEFILTERS(Effectif[SnapshotDate])
				)
			VAR ReportYear =
				COALESCE(
					IF(NOT ISBLANK(LatestSnapshot), YEAR(LatestSnapshot)),
					CALCULATE(MAX(Departs[SourceYear]), REMOVEFILTERS(Departs[SourceYear])),
					YEAR(TODAY())
				)
			RETURN
				COALESCE(
					CALCULATE(
						[Departures Count],
						FILTER(
							ALL(Departs[EventDate], Departs[DateDepart], Departs[MonthStartDate], Departs[SourceYear]),
							VAR DepartureDate = COALESCE(Departs[DateDepart], Departs[EventDate])
							VAR DepartureYear = IF(NOT ISBLANK(DepartureDate), YEAR(DepartureDate), Departs[SourceYear])
							RETURN DepartureYear = ReportYear
						)
					),
					0
				)
		formatString: 0
		displayFolder: 'Overview\Attrition'
		lineageTag: bea7da1c-d9c1-42c8-836e-28b375bdea3a

	measure 'Mobility Current Year' =
			VAR LatestSnapshot =
				CALCULATE(
					MAX(Effectif[SnapshotDate]),
					REMOVEFILTERS(Effectif[SnapshotDate])
				)
			VAR ReportYear =
				COALESCE(
					IF(NOT ISBLANK(LatestSnapshot), YEAR(LatestSnapshot)),
					CALCULATE(MAX(Departs[SourceYear]), REMOVEFILTERS(Departs[SourceYear])),
					YEAR(TODAY())
				)
			RETURN
				COALESCE(
					CALCULATE(
						[Departures Count],
						FILTER(
							ALL(Departs[EventDate], Departs[DateDepart], Departs[MonthStartDate], Departs[SourceYear], Departs[MotifDepartCode], Departs[PaysMobilite]),
							VAR DepartureDate = COALESCE(Departs[DateDepart], Departs[EventDate])
							VAR DepartureYear = IF(NOT ISBLANK(DepartureDate), YEAR(DepartureDate), Departs[SourceYear])
							VAR ReasonCode = UPPER(TRIM(COALESCE(Departs[MotifDepartCode], "")))
							VAR MobilityCountry = TRIM(COALESCE(Departs[PaysMobilite], ""))
							RETURN
								DepartureYear = ReportYear
									&& (
										ReasonCode = "MOBILITE"
										|| ReasonCode = "MOBILITY"
										|| ReasonCode = "MUTATION"
										|| LEN(MobilityCountry) > 0
									)
						)
					),
					0
				)
		formatString: 0
		displayFolder: 'Overview\Attrition'
		lineageTag: 236622bd-6e1e-43ba-aa39-c6ae20c0d11b

	measure 'Turnover Current Year' = DIVIDE([Departures Current Year], [Headcount])
		formatString: 0.0%
